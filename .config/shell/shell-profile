# ENV
# ---

USER_LANGUAGE="en_US.UTF-8"

export XDG_CACHE_HOME=~/.cache
export XDG_CONFIG_HOME=~/.config
export XDG_DATA_HOME=~/.local/share
export XDG_BIN_HOME=~/.local/bin
export SHELL_CONF_HOME=~/.config/shell
export LC_ALL=${USER_LANGUAGE}
export LANG=${USER_LANGUAGE}
export LANGUAGE=${USER_LANGUAGE}
export TERMCMD=st

# Wsl specific
if grep -qE "(Microsoft|WSL)" /proc/version &> /dev/null ; then
    export IS_WSL_DEVICE=true
    # IMPORTANT (for vim copy paste)
    export DISPLAY=:0
    # For wsl dir colors
    LS_COLORS="ow=01;36;40" && export LS_COLORS
    # Wsl file/folder permissions metadata
    umask 022
fi


# Program Variables
# -----------------

export JAVA_HOME="/usr/lib/jvm/java-8-openjdk-amd64/"
export VIM_HOME_DIR="$XDG_CONFIG_HOME/nvim"
export FZF_SOURCE_DIR="$XDG_CONFIG_HOME/.fzf"

# Editors
# -------

export EDITOR='nvim'
export GIT_EDITOR="$EDITOR"
export USE_EDITOR="$EDITOR"
export VISUAL=$EDITOR

# Paths
# -----

[ -d "$HOME/bin" ] && export PATH="$HOME/bin:$PATH"
[ -d "$HOME/.local/bin" ] && export PATH="$HOME/.local/bin:$PATH"

# Pager and flow
# --------------

export PAGER=less
export LESS='-iFMRSX -x4'
# make less more friendly for non-text input files, see lesspipe(1)
test -x /usr/bin/lesspipe && eval "$(SHELL=/bin/sh lesspipe)"
# disable flow control (ctrl + s,q)
stty -ixon
# Ignore basic commands in history
export HISTORY_IGNORE="(ls|bg|fg|pwd|exit|cd ..)"
