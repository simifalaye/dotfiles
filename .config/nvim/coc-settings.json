{
    "codeLens.enable": true,

    "diagnostic.enable": true,
    "diagnostic.enableSign": false,
    "diagnostic.maxWindowHeight": 20,

    "suggest.enablePreview": true,
    "suggest.detailField": "abbr",
    "suggest.maxCompleteItemCount": 30,

    "emmet.includeLanguages": { "vue": "html" },
    "emmet.showAbbreviationSuggestions" : true,

    "snippets.ultisnips.directories": [ "UltiSnips", "plugged/vim-snippets/UltiSnips" ],

    "vetur.validation.template": false,

    "languageserver": {
        "clangd": {
            "command": "clangd",
            "args": [
                "--query-driver=/home/**/arm-*g++",
                "--header-insertion=iwyu"
            ],
            "rootPatterns": ["compile_flags.txt", "compile_commands.json", ".git/", ".hg/"],
            "filetypes": ["c", "cpp", "objc", "objcpp"]
        }
    }
}
