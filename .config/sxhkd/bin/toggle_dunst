#!/bin/bash

# Description
# ===========
# Toggles dunst notifications
# Requirements: dunst
#
# Args: None
# Outputs: Error messages
# Side-effect: Starts or kills a dunst process

command -v dunst > /dev/null || { echo "Dunst is not installed."; exit 1; }

if pgrep -x dunst; then
    notify-send -i ubuntu-logo-icon "Disabling dunst"
    pkill -x dunst
else
    notify-send -i ubuntu-logo-icon "Enabling dunst"
    dunst -config "$HOME/.config/dunst/dunstrc" &
fi
