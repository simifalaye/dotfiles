# Run Rofi dmenu
super + @space
    rofi -combi-modi "window,drun" -show combi
super + p
    rofi-pass

# Media controls
# --------------

# Volume controls
XF86AudioRaiseVolume
    pactl set-sink-volume 0 +5%
XF86AudioLowerVolume
    pactl set-sink-volume 0 -5%
XF86AudioMute
    pactl set-sink-mute 0 toggle
