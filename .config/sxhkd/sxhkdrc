# vim: filetype=conf

# SXHKD module with WM-agnostic keys
#
# ~/.config/sxhkd/sxhkdrc

# Description
# ===========
#
# Configuration file for the Simple X Hotkey Daemon.

# Index with key chord chain mnemonics
# ====================================
#
# Key chord chains are used for less common commands, or
# for when assigning direct keybindings would become unwieldy.  The idea
# is to scope bindings so as to avoid conflicts.
#
# Environment: super + e ; ...
# Graphical applications: super + g ; ...

# Screenshots (requires `scrot`). The first one is of the entire X session
# (including all active monitors). The other one is for the focused window.
# Note that `scrot` also has an interactive mode that I do not use.
Print
    screenshot
shift + Print
    screenshot -w

# App launcher with dmenu
alt + @space
    j4-dmenu-desktop
# Select password from "pass" (requires "passmenu" script)
# Or select power menu
super + {p,P}
    {~/bin/lpass-dmenu copy,dmenu_power}

# Environment
# -----------

# The following commands are:
#
# c == toggle compton
# d == toggle dunst
# s == reload sxhkd
# v == vim cheatsheet
#
# Recall that these depend on files in ~/bin:
super + e ; {c,d,s,v}
    { \
    toggle_compton && notify-send -i ubuntu-logo-icon "Compton" "Toggled", \
    reload_dunst && notify-send -i ubuntu-logo-icon "Dunst" "Reloaded", \
    pkill -USR1 -x sxhkd && notify-send -i ubuntu-logo-icon "sxhkd config" "Reloaded key bindings", \
    st -e less $XDG_CONFIG_HOME/meta/cheatsheets/vim.txt \
    }

# Session management (lock)
super + l
    slock

# Graphical Apps
# --------------

# The following commands are:
#
# b == Firefox (Browser)
# f == NNN (Files)
# c == Calendar
super + g ; {b,f,c}
    { \
    notify-send -i firefox "Run GUI program" "Launching Browser" && firefox, \
    notify-send -i nautilus "Run GUI program" "Launching Files" && st -c "Vifm" -e zsh -ilc vifm, \
    notify-send -i gnome-calendar "Run GUI program" "Launching Cal" && gnome-calendar, \
    }

# Media controls
# --------------

# Volume controls
XF86AudioRaiseVolume
    change_volume inc
XF86AudioLowerVolume
    change_volume dec
XF86AudioMute
    change_volume mute
