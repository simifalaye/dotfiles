# vim: filetype=conf

# SXHKD module with WM-agnostic keys
#
# ~/.config/sxhkd/sxhkdrc
#
# Other modules should be available at ~/.config/sxhkd/
#

# Description
# ===========
#
# Partial configuration file for the Simple X Hotkey Daemon.  Meant to
# work with any WM.

# Index with key chord chain mnemonics
# ====================================
#
# Key chord chains are used for less common commands, or
# for when assigning direct keybindings would become unwieldy.  The idea
# is to scope bindings so as to avoid conflicts.
#
# Environment: super + e ; ...
# Executables which typically run in the console: super + x ; ...
# Graphical applications: super + g ; ...

# Run Rofi dmenu
super + @space
    rofi -show drun

# Terminal emulator with and without TMUX.
super + {_, shift + } Return
    {alacritty, alacritty -e zsh -l -c 'tmux -f ~/.config/tmux/tmux.conf new-session -A -s "Default"'}

# Screenshots (requires `scrot`). The first one is of the entire X session
# (including all active monitors). The other one is for the focused window.
# Note that `scrot` also has an interactive mode that I do not use.
Print
    scrot -m -z '%Y-%m-%d_%H:%M:%S_$wx$h.png' -e 'mv $f ~/Pictures' && \
    notify-send -i gnome-screenshot "Screen view screenshot" "Saved image to Pictures"
super + Print
    scrot -u -z '%Y-%m-%d_%H:%M:%S_$wx$h$n.png' -e 'mv $f ~/Pictures' && \
    notify-send -i gnome-screenshot "Window view screenshot" "Saved image to Pictures"

# Environment
# -----------

# The following commands are:
#
# c == toggle compositor
# d == toggle dunst
# k == toggle screenkey
# s == reload sxhkd
super + e ; {c, d, k, s}
    { \
    ~/.config/sxhkd/bin/toggle_picom, \
    ~/.config/sxhkd/bin/toggle_dunst, \
    ~/.config/sxhkd/bin/toggle_screenkey, \
    pkill -USR1 -x sxhkd && notify-send -i ubuntu-logo-icon "sxhkd config" "Reloaded key bindings" \
    }

# Session management (lock, sleep)
super + {_,shift + }BackSpace
    {slock, systemctl suspend && slock}

# Executables: CLI programs.
# -------------------------

# The following commands are:
#
# h == htop
# c == calc
super + x ; {h, c}
    alacritty -e zsh -l -c {'htop', 'calc'}

# Graphical Apps
# --------------

# The following commands are:
#
# a == Arandr (Browser)
# b == Firefox (Browser)
# f == Nautilus (Files)
# t == Tweaks
# c == Calendar
super + g ; {a, b, f, t, c}
    { \
    notify-send -i arandr "Run GUI program" "Arandr" && arandr, \
    notify-send -i firefox "Run GUI program" "Launching Browser" && firefox, \
    notify-send -i nautilus "Run GUI program" "Launching File Manager" && nautilus, \
    notify-send -i gnome-settings "Run GUI program" "Launching tweaks" && gnome-tweaks, \
    notify-send -i gnome-calendar "Run GUI program" "Launching Cal" && gnome-calendar, \
    }

# Media controls
# --------------

# Volume controls
XF86AudioRaiseVolume
    pactl set-sink-volume 0 +5%
XF86AudioLowerVolume
    pactl set-sink-volume 0 -5%
XF86AudioMute
    pactl set-sink-mute 0 toggle
