[settings]
screenchange-reload = true
;throttle-output-for = 10
;throttle-output = 5
;throttle-input-for = 40
;compositing-background = over
;compositing-background = screen
;compositing-foreground = xor
;compositing-foreground = source
;compositing-border = over


[colors]
background = #222
foreground = #eee
altforeground = #666
linecolor = #343d46
bordercolor = #333
accent = #343d46
alert = #88bf616a


[bar/top]
monitor = ${env:MONITOR:HDMI-1}
width = 100%
height = 24
background = ${colors.background}
foreground = ${colors.foreground}
line-color = ${colors.linecolor}
line-size = 2
font-0 = Hack:size=10:weight=medium;3
font-1 = FontAwesome:style=Regular:size=10;3
fixed-center = true
modules-left = i3 i3msg
modules-center =
modules-right = volume wired memory cpu dateTime
module-margin-left = 1
module-margin-right = 1
border-bottom-size = 2
border-bottom-color = ${colors.bordercolor}
scroll-up = i3wm-wsnext
scroll-down = i3wm-wsprev


[module/i3]
type = internal/i3
index-sort = true
enable-click = true
ws-icon-0 = 1; 
ws-icon-1 = 2; 
ws-icon-2 = 3; 
ws-icon-4 = 4; 
format = <label-state> <label-mode>
label-mode =
label-mode-background = ${colors.accent}
label-focused = %icon%
label-focused-background = ${colors.linecolor}
label-focused-foreground = ${colors.foreground}
label-focused-overline = ${colors.linecolor}
label-focused-underline = ${colors.linecolor}
label-focused-padding = 3
label-unfocused = %icon%
label-unfocused-padding = 3
label-urgent = %icon%!
label-urgent-background = #bd2c40
label-urgent-padding = 3
label-visible = %icon%
label-visible-padding = 3


[module/i3msg]
type = internal/i3
format =<label-state><label-mode>
label-mode = %mode%
label-mode-padding = 3
label-mode-background = ${colors.accent}
label-focused =
label-unfocused =
label-urgent =
label-visible =


[module/volume]
type = internal/alsa
master-mixer= Master
format-volume-padding = 0
format-muted-padding = 0
format-muted-background = ${colors.alert}
format-volume =  <label-volume>
format-muted =  off
label-volume = %percentage%%


[module/wired]
type = internal/network
interface = enp2s0
interval = 3.0

format-connected-prefix = "# "
format-connected-prefix-foreground = ${colors.altforeground}
label-connected = %local_ip%


[module/memory]
type = internal/memory
interval = 2
label = %percentage_used%%
format-prefix = "{} "
format-prefix-foreground = ${colors.altforeground}


[module/cpu]
type = internal/cpu
interval = 2
label = %percentage%%
format-prefix = " "
format-prefix-foreground = ${colors.altforeground}


[module/dateTime]
type = internal/date
date =%a %I:%M %p
format = <label>
format-background = ${colors.accent}
format-foreground = ${colors.foreground}
format-padding = 1
format-margin= 0


[module/xwindow]
type = internal/xwindow
format = <label>
label-maxlen = 75


[global/wm]
margin-top = 0
margin-bottom = 0
