[
        { "keys": [":", ";"], "type": "function", "command": "enter_command_line_mode" },
        { "keys": ["TAB", "l"], "type": "function", "command": "focus_next" },
        { "keys": ["SHIFT_TAB", "h"], "type": "function", "command": "focus_previous" },
        { "keys": ["UP", "k"], "type": "function", "command": "move_up" },
        { "keys": ["DOWN", "j"], "type": "function", "command": "move_down" },
        { "keys": ["PAGE_UP", "CTRL_U"], "type": "function", "command": "page_up" },
        { "keys": ["PAGE_DOWN", "CTRL_D"], "type": "function", "command": "page_down" },
        { "keys": ["ENTER"], "type": "function", "command": "activate" },
        { "keys": ["dd"], "type": "function", "command": "delete" },
        { "keys": ["gt"], "type": "exec", "command": "todo toggle $n" },
        { "keys": ["gc"], "type": "function", "command": "toggle_console" },
        { "keys": ["gm"], "type": "function", "command": "toggle_metadata" },
        { "keys": ["tl"], "type": "exec", "command": "tag notetags $n" },
        { "keys": ["ta"], "type": "prompt", "command": "tag add '' $n", "cursorPosition": -5 },
        { "keys": ["tr"], "type": "prompt", "command": "tag remove '' $n", "cursorPosition": -5 },
        { "keys": ["/"], "type": "prompt", "command": "search \"\"", "cursorPosition": -2 },
        { "keys": ["rn"], "type": "prompt", "command": "ren $c \"\"", "cursorPosition": -2 },
        { "keys": ["mn"], "type": "prompt", "command": "mknote \"\"", "cursorPosition": -2 },
        { "keys": ["mt"], "type": "prompt", "command": "mktodo \"\"", "cursorPosition": -2 },
        { "keys": ["mb"], "type": "prompt", "command": "mkbook \"\"", "cursorPosition": -2 },
        { "keys": ["yy"], "type": "prompt", "command": "cp $n \"\"", "cursorPosition": -2 },
        { "keys": ["mm"], "type": "prompt", "command": "mv $n ", "cursorPosition": -1 }
]
