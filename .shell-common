# make less more friendly for non-text input files, see lesspipe(1)
test -x /usr/bin/lesspipe && eval "$(SHELL=/bin/sh lesspipe)"

# enable color support of ls
if [ -x /usr/bin/dircolors ]; then
    test -r ~/.dircolors && eval "$(dircolors -b ~/.dircolors)" || eval "$(dircolors -b)"
fi

# disable flow control (ctrl + s,q)
stty -ixon

# ###################################################################
# Functions
# ###################################################################
# Command: mkcd - makes a directory and cd's into it
function mkcd {
    command mkdir $1 && cd $1
}
# Command: Push dotfiles to github
function dotfiles() {
    message="Latest file updates"
    [ -z "$1" ] || message=${1}
    command yadm commit -a -m "$message"
    command yadm push
}
# Command: Reload the current shell
function reloadshell() {
    currentshell=$(ps -fp $$)
    if [[ $currentshell =~ "zsh" ]]; then
        zgen reset && source ~/.zshrc && echo "Zsh reloaded."
    elif [[ $currentshell =~ "bash" ]]; then
        source ~/.bashrc && echo "Bash reloaded."
    else
        echo "Failed to reload shell."
    fi
}
# Command: ls when changing dirs
function cd() {
    builtin cd "$1" && ls
}
# Command: open config file
function conf() {
    if [[ $1 == "vim" ]]; then
        command $EDITOR $VIM_HOME_DIR/*.vim
        return
    elif [[ $1 == "tmux" ]]; then
        filename="$HOME/.tmux.conf"
    elif [[ $1 == "zsh" ]]; then
        filename="$HOME/.zshrc"
    else
        filename="$HOME/.config/$1/config"
    fi

    command $EDITOR $filename
}
