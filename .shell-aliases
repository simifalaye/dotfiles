########## Aliases ##########

# Editor
alias vim="nvim"

# ls aliases
alias ls='ls --color=auto'
alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'

# grep aliases
alias grep="grep --color=auto --exclude-dir={.bzr,CVS,.git,.hg,.svn}"
alias fgrep='fgrep --color=auto'
alias egrep='egrep --color=auto'

# bat aliases (a better cat)
command -v bat >/dev/null && alias cat="bat -p"

# gotop aliases (a graphical top)
command -v gotop >/dev/null && alias tm="gotop"

# tmux aliases
command -v tmux >/dev/null && {
    alias tmux='tmux -f "$XDG_CONFIG_HOME/tmux/tmux.conf"'
    alias ta='tmux attach -t'
    alias tl='tmux ls'
}

# navigation aliases
alias home="cd ~"
alias dev="cd ~/dev"
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias .....='cd ../../../..'
alias ......='cd ../../../../..'
alias .......='cd ../../../../../..'
alias ........='cd ../../../../../../..'
alias .........='cd ../../../../../../../..'

########## Private Functions ##########

function _is_interactive { [[ $- == *i* || -n $EMACS ]]; }

function _is_callable
{
    for cmd in "$@"; do
        command -v "$cmd" >/dev/null || return 1
    done
}

function _is_wsl
{
    if grep -qE "(Microsoft|WSL)" /proc/version &> /dev/null ; then
        return 0
    fi
    return 1
}

function _load
{
    test -r $1 && source $1 || echo "Failed to source $1"
}

function _load_all
{
    for src in "$@"; do
        _load $src
    done
}

function _load_repo
{
    local target=$1
    local dest=$2
    local src=$3
    if [ ! -d $dest ]; then
        url=https://github.com/$target
        mkdir -p $dest
        git clone "$url" "$dest" || >&2 echo "Failed to load repo $url"
    fi
    [ -z "$src" ] || _load $dest/$src
}

########## Public Functions ##########

# Push dotfiles to github
function dotfiles()
{
    message="Latest file updates"
    [ -z "$1" ] || message=${1}
    command yadm commit -a -m "$message"
    command yadm push
}

# ls when changing dirs
function cd()
{
    builtin cd "$1" && ls
}

# open config file
function conf()
{
    prog=$1
    [ "$prog" == "vim" ] && prog="nvim"

    command $EDITOR $HOME/.config/$prog
}

# Command: Reload the current shell
function reloadshell()
{
    currentshell=$(ps -fp $$)
    if [[ $currentshell =~ "zsh" ]]; then
        zgen reset && source $ZSHRC_FILE_LOC && echo "Zsh reloaded."
    elif [[ $currentshell =~ "bash" ]]; then
        source $BASHRC_FILE_LOC && echo "Bash reloaded."
    else
        echo "Failed to reload shell."
    fi
}

