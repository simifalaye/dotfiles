#!/bin/bash
# vim: ft=sh
# A screenshot utility
#
# Screenshots (requires `scrot`). The first one is of the entire X session
# (including all active monitors). The other one is for the focused window.
# Note that `scrot` also has an interactive mode that I do not use.

DIR="$HOME/Pictures/scrots/"

function print_help() {
    echo "Usage: $0 <argument>"
    echo "-f: Fullscreen"
    echo "-s: Select an Area"
    echo "-w: Select a Window"
}

function send_noti() {
    notify-send -i gnome-screenshot "screenshot" "Screenshot has been saved to $DIR."
}

mkdir -p $DIR
if [ $# -eq 0 ]; then
    sleep 0.2 && scrot 'scrot-%F_%H%M%S_$wx$h.png' -e 'mv $f '$DIR'' && send_noti
elif [ $# -eq 1 ]; then
    case $1 in
        "-h") print_help;;
        "-f") sleep 0.2 && scrot 'scrot-%F_%H%M%S_$wx$h.png' -e 'mv $f '$DIR'' && send_noti;;
        "-s") sleep 0.2 && scrot -sz 'scrot-%F_%H%M%S_$wx$h.png' -e 'mv $f '$DIR'' && send_noti;;
        "-w") sleep 0.2 && scrot -u 'scrot-%F_%H%M%S_$wx$h.png' -e 'mv $f '$DIR'' && send_noti;;
        *) print_help;;
    esac
else
    print_help
fi
