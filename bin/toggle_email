#!/bin/sh

# Description
# ===========
# Displays neomutt email
# Requirements:
#   - xdo
#   - neomutt
#
# Args: None
# Outputs: Nothing
# Side-effect: Starts a neomutt floating window or toggles
#              its hidden state if already running

NAME="Email"
CLASS="scratchpad"
id=$(xdo id -n $NAME);

if [ -z "$id" ]; then
  st -c $CLASS -n $NAME -e neomutt &

  sleep 0.1
  id=$(xdo id -n $NAME);
  if [ ! -z "$id" ]; then
    xdo activate -n $NAME
  fi
else
  action='hide';
  case "$(xprop -id $id | awk '/window state: / {print $3}')" in
      *drawn*)
          action='show'
          ;;
  esac

  xdo $action -n $NAME
  xdo activate -n $NAME
fi
