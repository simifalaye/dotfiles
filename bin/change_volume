#!/bin/bash
# vim: ft=sh

# Volume controls
# ================
# Requirements:
# - Following scripts must be executable in $PATH:
#     # get_progress_string
#     # volume_amixer
requirements=get_progress_string,volume_amixer

for cmd in $(echo $requirements | sed "s/,/ /g"); do
    command -v "$cmd" >/dev/null || {
        echo "Requires: $cmd" && exit 1
    }
done

# Main
# ======

# Message ID
msgId="991049"

volume_status="$(volume_amixer status)"
volume_level="$(volume_amixer level)"
# Change the volume or toggle mute
case $1 in
    inc)
        [ "$volume_status" = "off" ] && pactl set-sink-mute 0 toggle
        pactl set-sink-volume 0 +5%
        ;;
    dec)
        [ "$volume_status" = "off" ] && pactl set-sink-mute 0 toggle
        pactl set-sink-volume 0 -5%
        ;;
    mute)
        pactl set-sink-mute 0 toggle
        ;;
    *)
        echo "Error: Not a valid volume command"
esac

# Cap volume
if [ $volume_level -gt 100 ]; then
    pactl set-sink-volume 0 100% && volume_level=100
elif [ $volume_level -lt 0 ]; then
    pactl set-sink-volume 0 0% && volume_level=0
fi

if [ "$volume_level" = 0 ] || [ "$volume_status" = "off" ]; then
    # mute
    dunstify -a "changeVolume" -u low -i notification-audio-volume-muted -r "$msgId" "Volume muted"
else
    # volume notification
    dunstify -a "changeVolume" -u low -i notification-audio-volume-high -r "$msgId" \
        "Volume: ${volume_level}%" "$(get_progress_string 10 "<b>◉ </b>" "○ " "$volume_level")"
fi

# Play sound
canberra-gtk-play -i audio-volume-change -d "changeVolume"
