#!/bin/bash
# vim: ft=sh
# A screenshot utility
#
# Screenshots (requires `scrot`). The first one is of the entire X session
# (including all active monitors). The other one is for the focused window.
# Note that `scrot` also has an interactive mode that I do not use.

usage()
{
    echo "Usage: screenshot <option>"
    echo "Takes a screenshot of entire X session including all active monitors"
    echo "Options:"
    echo "    -c: screenshot only the focused window"
    exit 0
}

[[ $# -ge 2 ]] && usage

case "$1" in
    -c)
        scrot -u -z '%y-%m-%d_%h:%m:%s_$wx$h$n.png' -e 'mv $f ~/pictures' && \
        notify-send -i gnome-screenshot "window view screenshot" "saved image to pictures"
        ;;
    *)
        scrot -m -z '%y-%m-%d_%h:%m:%s_$wx$h.png' -e 'mv $f ~/pictures' && \
        notify-send -i gnome-screenshot "screen view screenshot" "saved image to pictures"
        ;;
esac
