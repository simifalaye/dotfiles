#!/bin/bash

# Globals
# -------
USAGE="Usage: $0 <recipe_name> <src_path>"
BBAPPEND_COMM="# GENERATED: YOCTOCPP..."
BBAPPEND_CONF="\
$BBAPPEND_COMM
GEN_COMPILATION_DB_PATH = \"{VAR_SRCPATH}\"
inherit compilation_db
# END GENERATED"

C_FLAGS="\
%compile_commands.json
%c -std=c11
-Wall
-Wextra
-Werror
-Wno-long-long
-Wno-variadic-macros
-fexceptions
-ferror-limit=10000
-DNDEBUG
-I/usr/lib/
-I/usr/include/"
CPP_FLAGS="\
%compile_commands.json
%h -x
%h c++-header
%cpp -std=c++17
-Wall
-Wextra
-Wno-long-long
-Wno-variadic-macros
-fexceptions
-ferror-limit=10000
-DNDEBUG
-I/usr/lib/
-I/usr/include/
-xc++
-isystem/usr/include/c++/8
-isystem/usr/include/x86_64-linux-gnu/c++/8
-isystem/usr/include/c++/8/backward
-isystem/usr/lib/gcc/x86_64-linux-gnu/8/include
-isystem/usr/local/include
-isystem/usr/lib/gcc/x86_64-linux-gnu/8/include-fixed
-isystem/usr/include/x86_64-linux-gnu
-isystem/usr/include"

# Functions
# ---------
_err()
{
    echo -e "ERROR: $1"
    exit 1
}

_is_callable()
{
    for cmd in "$@"; do
        command -v "$cmd" >/dev/null || return 1
    done
}

PROGRESS()
{
    echo -e "\nStep: $1...\n"
}

# MAIN
# ====
RECIPE=${1}
SRCPATH=${2}

PROGRESS "Validating"

# Check if in build appliance
_is_callable devtool bitbake && [ -n "$BUILDDIR" ] || _err "Must be inside build appliance"
# Invoke  usage
[[ $# -ne 2 ]] | [[ -d $SRCPATH ]] || _err "$USAGE"

PROGRESS "Setup devtool"

# Run devtool if not already devtool'd
stat=$(devtool status)
if ! echo "$stat" | grep -q "$RECIPE:"; then
    devtool modify -n "$RECIPE" "$SRCPATH" || _err "Devtool failed"
    sleep 1
fi

PROGRESS "Configuring workspace"

# Add config to bbappend
bbappend_file=$(ls -1 $BUILDDIR/workspace/appends/$RECIPE*.bbappend | head -n1)
if [ -f "$bbappend_file" ]; then
    echo "Found bbapend file: $bbappend_file"
    # Check if already configured
    if ! grep -Fxq "$BBAPPEND_COMM" $bbappend_file >/dev/null 2>&1; then
        out=$(cat $bbappend_file)
        gen=$(echo -e "$BBAPPEND_CONF" | sed -e "s|{VAR_SRCPATH}|${SRCPATH}|g")
        echo "" > $bbappend_file
        while IFS= read -r line; do
            echo -e "$line" >> $bbappend_file
            [[ $line == "inherit externalsrc" ]] && echo -e "\n$gen\n" >> $bbappend_file
        done <<< "$out"
    fi
fi

PROGRESS "Building"

# Build
bitbake $RECIPE || _err "Failed to build $RECIPE"

PROGRESS "Configuring ccls"

# Add .ccls file to project
echo -e "$CPP_FLAGS" > "$SRCPATH/.ccls"

# Return
exit 0
