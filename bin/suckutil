#!/bin/bash
# vim: ft=sh

# A utility for suckless git projects

function print_help() {
    echo "Usage: $0 <argument>"
    echo "Args:"
    echo "    reset: clean develop and reset to origin develop"
    echo "    add <patch-file> <branch-name>: checkout a branch and apply a patch"
    echo "    delete <branch-name> : delete a patch branch"
    echo "    merge <exclude>...: merge all (except for 'exclude') local branches into develop"
    echo "    build: reset, merge and build"
}

function _goto_branch() {
    if ! git checkout ${1} > /dev/null 2>&1; then
        echo "ERROR: Branch does not exist: ${1}"
        print_help
        exit 1
    fi
}

function _clean() {
    echo "Cleaning..."
    rm -rf config.h && sudo make clean > /dev/null 2>&1 && return 0
    return 1
}

function reset() {
    echo "Reseting develop..."
    _goto_branch develop && _clean && {
        git reset --hard origin/develop > /dev/null 2>&1 && return 0
    }
    return 1
}

function add() {
    branch=${1}
    patch=${2}

    echo "Adding patch: $branch..."
    git checkout -b $branch && {
        git apply $patch && {
            echo "Patch has been added on branch '$branch'"
            echo "Make any changes and 'git push origin $branch' when done"
            git status
            return 0
        }
    }
    return 1
}

function delete() {
    branch=${1}
    ret=1

    echo "Deleting patch: $branch..."
    # Delete local branch
    git branch -D $branch > /dev/null 2>&1 && ret=0
    # Delete remote branch
    read -p "Delete remote branch also (y/n)? " choice
    case "$choice" in
        y|Y)
            git push origin --delete $branch && ret=0 || ret=1
            ;;
        *)
            echo "Remote branch not deleted"
            ;;
    esac

    return ${ret}
}

function merge() {
    exclude="${1} develop master"
    for branch in $(git for-each-ref --format='%(refname)' refs/heads/ | cut -d'/' -f3); do
        if ! echo "$exclude" | grep -wq "$branch"; then
            echo "Merging: $branch..."
            echo "-------------------"
            git merge $branch -m $branch
        fi
    done
}

# Main
# =====

case $1 in
    reset)
        reset && exit 0
        ;;
    add)
        patch="$2"
        branch="$3"
        if [ -z "$branch" ] || [ ! -f "$patch" ]; then
            print_help && exit 1
        fi
        reset && add $branch $patch && exit 0
        ;;
    delete)
        branch="$2"
        if [ -z "$branch" ]; then
            print_help && exit 1
        fi
        reset && delete $branch && exit 0
        ;;
    merge)
        shift 1
        reset && merge $@ && exit 0
        ;;
    build)
        reset && merge && sudo make clean install && exit 0
        ;;
    *)
        print_help && exit 1
        ;;
esac
